  "description": "Per-service board for the NetBird management server (job=\"netbird-server\", scraped at 172.17.0.2:9090). Instruments verified against netbird v0.74.3; counter/histogram selectors use __name__ regex with optional OTel-exporter suffixes (see panel descriptions). Datasource is the fixed provisioned uid \"victoriametrics\".",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "gRPC server",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "title": "Connected peer streams",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Active peer gRPC streams (management_grpc_connected_streams). 0 means no peers connected.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "0"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(management_grpc_connected_streams{job=\"netbird-server\"})",
          "legendFormat": "",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "title": "gRPC request rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Requests/s per gRPC endpoint (sync/login/key request counters).",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 10,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "gradientMode": "none"
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "range": true,
          "expr": "sum(rate({__name__=~\"management_grpc_sync_request_counter(_total)?\",job=\"netbird-server\"}[5m]))",
          "legendFormat": "sync"
        },
        {
          "refId": "B",
          "range": true,
          "expr": "sum(rate({__name__=~\"management_grpc_login_request_counter(_total)?\",job=\"netbird-server\"}[5m]))",
          "legendFormat": "login"
        },
        {
          "refId": "C",
          "range": true,
          "expr": "sum(rate({__name__=~\"management_grpc_key_request_counter(_total)?\",job=\"netbird-server\"}[5m]))",
          "legendFormat": "key"
        }
      ]
    },

    {
      "id": 3,
      "title": "Connected peer streams",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Live gRPC streams from peers to the management server (management_grpc_connected_streams_ratio; the '_ratio' suffix is the OTel exporter's unit tag, the value is a stream count). 0 = no peers connected.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "0"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(management_grpc_connected_streams_ratio{job=\"netbird-server\"})",
          "legendFormat": "",
          "range": true
        }
      ]
    },

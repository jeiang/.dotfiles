      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Count of systemd units in the failed state fleet-wide. Mirrors the SystemdUnitFailed alert signal.",
      "gridPos": {

      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Fleet landing board for the Legion nodes. Health is derived from the raw signals (node_* metrics, up, node_systemd_unit_state, probe_success) rather than an ALERTS series on purpose: vmalert in modules/nixos/monitoring/default.nix has no remoteWrite, so it does not persist an ALERTS metric into VictoriaMetrics. Adding remoteWrite is deliberately out of scope. Datasource is referenced by the stable uid 'victoriametrics' set on the provisioned VictoriaMetrics datasource in that same module.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Per-node health",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "title": "CPU busy %",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "CPU utilisation per node (100% minus idle) over a 5m rate window.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "minVizWidth": 0,
        "minVizHeight": 10,
        "orientation": "horizontal",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"node\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory used %",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Memory utilisation per node (100% minus MemAvailable/MemTotal), matching the HighMemoryUsage alert expression.",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "minVizWidth": 0,
        "minVizHeight": 10,
        "orientation": "horizontal",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"} * 100)",
          "legendFormat": "{{instance}}",
          "range": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Root filesystem used %",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Root (/) filesystem usage per node. Same fstype!~\"tmpfs|overlay\" filter as the HighDiskUsage alert; scoped to mountpoint=\"/\".",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "minVizWidth": 0,
        "minVizHeight": 10,
        "orientation": "horizontal",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (node_filesystem_avail_bytes{job=\"node\",fstype!~\"tmpfs|overlay\",mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"node\",fstype!~\"tmpfs|overlay\",mountpoint=\"/\"} * 100)",
          "legendFormat": "{{instance}}",
          "range": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Availability",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 6,
      "title": "Targets up",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Count of scrape targets currently up (up == 1).",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "0"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(up == 1) or vector(0)",
          "legendFormat": "",
          "range": true
        }
      ]
    },

    {
      "id": 10,
      "title": "Scrape targets up/down",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Every scrape target and its current up state (1 = up, 0 = down), keyed by job and instance.",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "up"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "DOWN",
                        "color": "red",
                        "index": 0
                      },
                      "1": {
                        "text": "UP",
                        "color": "green",
                        "index": 1
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]

  "description": "Per-service board for the edge Caddy reverse proxy (job=\"caddy\", scraped at 172.17.0.1:2020). Metric names verified against caddy v2.11.4 sources. Datasource is the fixed provisioned uid \"victoriametrics\" (modules/nixos/monitoring/default.nix), as in fleet-overview.json.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "HTTP requests",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "title": "Request rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Requests/s handled by Caddy, split by server. Sum of caddy_http_requests_total rate.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "gradientMode": "none"
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "range": true,
          "expr": "sum by (server) (rate(caddy_http_requests_total{job=\"caddy\"}[5m]))",
          "legendFormat": "{{server}}"
        },
        {
          "refId": "B",
          "range": true,
          "expr": "sum(rate(caddy_http_requests_total{job=\"caddy\"}[5m]))",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requests by status code",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Requests/s by HTTP status code. Derived from the request-duration histogram _count series, which carries the `code` label (caddy_http_requests_total does not).",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "gradientMode": "none",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "range": true,
          "expr": "sum by (code) (rate(caddy_http_request_duration_seconds_count{job=\"caddy\"}[5m]))",
          "legendFormat": "{{code}}"
        }
      ]
    },

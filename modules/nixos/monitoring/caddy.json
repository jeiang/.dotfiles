      },
      "targets": [
        {
          "refId": "A",
          "range": true,
          "expr": "histogram_quantile(0.50, sum by (le) (rate(caddy_http_request_duration_seconds_bucket{job=\"caddy\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "range": true,
          "expr": "histogram_quantile(0.90, sum by (le) (rate(caddy_http_request_duration_seconds_bucket{job=\"caddy\"}[5m])))",
          "legendFormat": "p90"
        },
        {
          "refId": "C",
          "range": true,
          "expr": "histogram_quantile(0.99, sum by (le) (rate(caddy_http_request_duration_seconds_bucket{job=\"caddy\"}[5m])))",
          "legendFormat": "p99"
        }
